rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAllowedEmail() {
      return request.auth != null &&
             request.auth.token.email in [
               'yooyoopd@gmail.com',
               '2yeonsoo@gmail.com'
             ];
    }

    function isAnonGuest() {
      return request.auth != null
             && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) && isAllowedEmail();

      match /trips/{tripId} {
        allow get:   if (isOwner(userId) && isAllowedEmail())
                     || (isAnonGuest() && resource.data.guestCode != null);
        allow list:  if isOwner(userId) && isAllowedEmail();
        allow write: if isOwner(userId) && isAllowedEmail();

        match /itinerary/{itemId} {
          allow read:  if (isOwner(userId) && isAllowedEmail())
                       || (isAnonGuest() && get(/databases/$(database)/documents/users/$(userId)/trips/$(tripId)).data.guestCode != null);
          allow write: if isOwner(userId) && isAllowedEmail();
        }
        match /bookings/{itemId} {
          allow read:  if (isOwner(userId) && isAllowedEmail())
                       || (isAnonGuest() && get(/databases/$(database)/documents/users/$(userId)/trips/$(tripId)).data.guestCode != null);
          allow write: if isOwner(userId) && isAllowedEmail();
        }
        match /activities/{activityId} {
          allow read:  if (isOwner(userId) && isAllowedEmail())
                       || (isAnonGuest() && get(/databases/$(database)/documents/users/$(userId)/trips/$(tripId)).data.guestCode != null);
          allow write: if isOwner(userId) && isAllowedEmail();
        }
        match /expenses/{expenseId} {
          allow read:  if (isOwner(userId) && isAllowedEmail())
                       || (isAnonGuest() && get(/databases/$(database)/documents/users/$(userId)/trips/$(tripId)).data.guestCode != null);
          allow write: if isOwner(userId) && isAllowedEmail();
        }
      }
    }

    // Guest code lookup — point reads only; listing all codes is blocked
    match /guest_codes/{code} {
      allow get:   if request.auth != null;
      allow list:  if false;
      allow write: if isAllowedEmail();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
